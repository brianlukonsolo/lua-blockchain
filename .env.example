BLOCKCHAIN_MODE=production
BLOCKCHAIN_PORT=8080
BLOCKCHAIN_NODE_ID=node-1
BLOCKCHAIN_NODE_URL=https://node-1.example.com
BLOCKCHAIN_CHAIN_ID=lua-blockchain-mainnet
BLOCKCHAIN_DIFFICULTY=0000
BLOCKCHAIN_REWARD=1
BLOCKCHAIN_PEER_TIMEOUT_SECONDS=5
BLOCKCHAIN_MAX_PEERS=64
BLOCKCHAIN_MAX_PENDING_TRANSACTIONS=5000
BLOCKCHAIN_MAX_TRANSACTIONS_PER_BLOCK=250
BLOCKCHAIN_MIN_TRANSACTION_FEE=0.01
BLOCKCHAIN_MAX_TRANSACTION_NOTE_BYTES=280
BLOCKCHAIN_REQUIRE_HTTPS_PEERS=true
BLOCKCHAIN_ENABLE_SERVER_WALLETS=false
BLOCKCHAIN_PUBLIC_RATE_LIMIT_PER_MINUTE=240
BLOCKCHAIN_ADMIN_RATE_LIMIT_PER_MINUTE=60
BLOCKCHAIN_PEER_RATE_LIMIT_PER_MINUTE=600
BLOCKCHAIN_ADMIN_TOKEN=replace-with-a-long-random-admin-token
BLOCKCHAIN_PEER_SHARED_SECRET=replace-with-a-long-random-peer-secret
BLOCKCHAIN_ALLOWED_PEER_HOSTS=node-1.example.com,node-2.example.com,node-3.example.com
